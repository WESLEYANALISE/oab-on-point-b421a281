# Variáveis públicas (vão para o bundle do cliente)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Variáveis do servidor (NUNCA prefixe com VITE_)
# Configure no painel da plataforma (Supabase / Lovable Secrets):
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_URL=
# GEMINI_API_KEY=
# GEMINI_API_KEY_2=
# BROWSERLESS_API_KEY=
# MISTRAL_API_KEY=
